# Local LLM cluster (OpenAI-compatible /v1).
# Comma or newline separated; first reachable endpoint wins. Set to your
# own LAN nodes (e.g. http://10.0.0.5:1234) or a single localhost server.
LARP_LLM_ENDPOINTS=http://127.0.0.1:1234

# Chat model for director, personas, and meeting turns.
LARP_LLM_MODEL=your-chat-model

# Fallback model if primary fails.
LARP_LLM_MODEL_FALLBACK=your-fallback-model

# Optional bearer token; leave blank for open LAN access.
LARP_LLM_API_KEY=
