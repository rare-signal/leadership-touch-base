# LARP-meeting uses David's local LLM cluster (OpenAI-compatible /v1).
# Comma or newline separated; first reachable endpoint wins.
LARP_LLM_ENDPOINTS=http://192.168.86.243:1234,http://192.168.86.250:1234,http://192.168.86.39:1234

# Chat model for director, personas, and meeting turns. crow is a Claude-distilled
# Qwen3.5 fine-tune that's good for character voicework.
LARP_LLM_MODEL=crow-9b-opus-4.6-distill-heretic_qwen3.5

# Fallback model if primary fails.
LARP_LLM_MODEL_FALLBACK=qwen/qwen3.5-9b

# Optional bearer token; leave blank for open LAN access.
LARP_LLM_API_KEY=
