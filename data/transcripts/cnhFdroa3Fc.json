  "segments": [
    {
      "start": 0.0,
      "end": 1.96,
      "text": "I just wanted to quickly flag that the Daylight Savings",
      "avg_logprob": -0.2458,
      "speaker_turn": 0
    },
    {
      "start": 1.96,
      "end": 4.22,
      "text": "Adjustment is this weekend, right?",
      "avg_logprob": -0.2458,
      "speaker_turn": 0
    },
    {
      "start": 4.4,
      "end": 6.62,
      "text": "So we will effectively be dealing with one less hour",
      "avg_logprob": -0.2458,
      "speaker_turn": 0
    },
    {
      "start": 6.62,
      "end": 7.78,
      "text": "in the weekly time envelope.",
      "avg_logprob": -0.2458,
      "speaker_turn": 0
    },
    {
      "start": 7.92,
      "end": 10.02,
      "text": "And I did just write it all out there, go ahead.",
      "avg_logprob": -0.2458,
      "speaker_turn": 0
    },
    {
      "start": 10.44,
      "end": 12.9,
      "text": "Operationally speaking, if not properly mitigated,",
      "avg_logprob": -0.2458,
      "speaker_turn": 0
    },
    {
      "start": 13.04,
      "end": 15.18,
      "text": "this seemingly minor temporal compression",
      "avg_logprob": -0.2458,
      "speaker_turn": 0
    },
    {
      "start": 15.77,
      "end": 17.84,
      "text": "can create sizable downstream headwinds",
      "avg_logprob": -0.2458,
      "speaker_turn": 0
    },
    {
      "start": 17.84,
      "end": 19.0,
      "text": "for us to correct for, right?",
      "avg_logprob": -0.2458,
      "speaker_turn": 0
    },
    {
      "start": 19.2,
      "end": 20.18,
      "text": "It's a great input there.",
      "avg_logprob": -0.2458,
      "speaker_turn": 0
    },
    {
      "start": 20.3,
      "end": 21.64,
      "text": "And if I might bug that out real quick,",
      "avg_logprob": -0.2458,
      "speaker_turn": 0
    },
    {
      "start": 21.92,
      "end": 24.32,
      "text": "it's no question that we must proactively reclaim",
      "avg_logprob": -0.2458,
      "speaker_turn": 0
    },
    {
      "start": 24.32,
      "end": 26.08,
      "text": "that hour from a workflow standpoint",
      "avg_logprob": -0.2458,
      "speaker_turn": 0
    },
    {
      "start": 26.08,
      "end": 29.04,
      "text": "if we are to prevent any daylight-induced productivity",
      "avg_logprob": -0.2458,
      "speaker_turn": 0
    },
    {
      "start": 29.04,
      "end": 30.02,
      "text": "decline, right?",
      "avg_logprob": -0.3527,
      "speaker_turn": 0
    },
    {
      "start": 30.18,
      "end": 30.92,
      "text": "So I'm very sure.",
      "avg_logprob": -0.3527,
      "speaker_turn": 0
    },
    {
      "start": 30.92,
      "end": 31.44,
      "text": "Totally, totally.",
      "avg_logprob": -0.3527,
      "speaker_turn": 0
    },
    {
      "start": 31.44,
      "end": 33.12,
      "text": "And to draw down a little deeper there,",
      "avg_logprob": -0.3527,
      "speaker_turn": 0
    },
    {
      "start": 33.64,
      "end": 35.38,
      "text": "like strategically, I think it's a matter of,",
      "avg_logprob": -0.3527,
      "speaker_turn": 0
    },
    {
      "start": 35.42,
      "end": 38.22,
      "text": "okay, how do we solve for less week?",
      "avg_logprob": -0.3527,
      "speaker_turn": 0
    }
